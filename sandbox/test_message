#!/bin/bash
# Send one message through the sandbox pipeline and return the result.
# Usage: echo "your message" | ./test_message [--admin] [--jid <id>] [--resume <session_id>]
#
# Stdout : raw JSON from Claude (same format as production)
# Stderr : sandbox diagnostics + "[session_id] <id>" for easy chaining
#
# Exit codes: 0 = success, 1 = Claude/sandbox error

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

CONV_ID="test_default"
IS_ADMIN="false"
SESSION_ID=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --admin)   IS_ADMIN="true"; shift ;;
        --jid)     CONV_ID="$2"; shift 2 ;;
        --resume)  SESSION_ID="$2"; shift 2 ;;
        *) echo "[test_message] Unknown option: $1" >&2; exit 1 ;;
    esac
done

CLAUDE_ARGS=("--auto-approve")

if [[ "$IS_ADMIN" == "true" ]]; then
    CLAUDE_ARGS+=("--permission-mode" "bypassPermissions")
else
    CLAUDE_ARGS+=(
        "--permission-mode" "dontAsk"
        "--system-prompt" "You are a helpful test assistant. Respond briefly and accurately."
    )
fi

if [[ -n "$SESSION_ID" ]]; then
    CLAUDE_ARGS+=("--resume" "$SESSION_ID")
fi

PROMPT=$(cat)

echo "[test_message] jid=$CONV_ID admin=$IS_ADMIN session=${SESSION_ID:-(none)}" >&2

RAW=$(echo "$PROMPT" | "$SCRIPT_DIR/launch" "$CONV_ID" "${CLAUDE_ARGS[@]}")

# Extract session_id and print to stderr for easy chaining
SESSION=$(echo "$RAW" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('session_id', ''))
except:
    pass
" 2>/dev/null || true)

if [[ -n "$SESSION" ]]; then
    echo "[session_id] $SESSION" >&2
fi

echo "$RAW"
