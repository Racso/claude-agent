#!/bin/bash
# Launches Claude inside a bwrap sandbox with a request_access escape hatch.
# Usage: echo "prompt" | ./launch <conv_id> [--auto-approve] [claude args...]
# Output: claude's JSON response on stdout; sandbox messages on stderr.
#
# The workspace at /tmp/claude_sandbox_<conv_id> persists across calls so
# approved files carry over between messages in the same conversation.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

CONV_ID="${1:?Usage: launch <conv_id> [--auto-approve] [claude args...]}"
shift

AUTO_APPROVE="false"
CLAUDE_ARGS=()
for arg in "$@"; do
    case "$arg" in
        --auto-approve) AUTO_APPROVE="true" ;;
        *) CLAUDE_ARGS+=("$arg") ;;
    esac
done

# Stable workspace per conversation — persists between calls
WORKSPACE="/tmp/claude_sandbox_$CONV_ID"
mkdir -p "$WORKSPACE/.requests" "$WORKSPACE/.responses" "$WORKSPACE/.handled" "$WORKSPACE/.bin"
echo "[sandbox] Workspace: $WORKSPACE" >&2

# Inject request_access (refresh on every call in case it was updated)
cp "$SCRIPT_DIR/request_access" "$WORKSPACE/.bin/request_access"
chmod +x "$WORKSPACE/.bin/request_access"

# Ensure contacts.json exists so we can bind-mount it rw
[[ -f "$PROJECT_DIR/contacts.json" ]] || echo '{}' > "$PROJECT_DIR/contacts.json"

# Start the host-side watcher
"$SCRIPT_DIR/watcher" "$WORKSPACE" "$AUTO_APPROVE" &
WATCHER_PID=$!

cleanup() {
    kill "$WATCHER_PID" 2>/dev/null || true
    # Clean per-session dirs but preserve workspace and approved files
    rm -rf "$WORKSPACE/.requests" "$WORKSPACE/.responses" "$WORKSPACE/.handled"
    echo "[sandbox] Session ended. Workspace preserved: $WORKSPACE" >&2
}
trap cleanup EXIT

bwrap \
    --unshare-all \
    --share-net \
    \
    --ro-bind /usr /usr \
    --symlink usr/lib    /lib \
    --symlink usr/lib64  /lib64 \
    --symlink usr/bin    /bin \
    --symlink usr/sbin   /sbin \
    \
    --ro-bind /etc/resolv.conf       /etc/resolv.conf \
    --ro-bind /etc/ssl/certs         /etc/ssl/certs \
    --ro-bind /etc/nsswitch.conf     /etc/nsswitch.conf \
    --ro-bind /etc/hosts             /etc/hosts \
    --ro-bind /etc/passwd            /etc/passwd \
    --ro-bind /etc/group             /etc/group \
    \
    --tmpfs "$HOME" \
    --dir   "$HOME/.local" \
    --dir   "$HOME/.local/share" \
    --dir   "$HOME/.local/bin" \
    --ro-bind "$HOME/.local/share/claude" "$HOME/.local/share/claude" \
    --ro-bind "$HOME/.local/bin"          "$HOME/.local/bin" \
    --bind   "$HOME/.claude"              "$HOME/.claude" \
    --bind   "$HOME/.claude.json"         "$HOME/.claude.json" \
    \
    --ro-bind "$PROJECT_DIR"              /claude_wa \
    --bind   "$PROJECT_DIR/contacts.json" /workspace/contacts.json \
    --bind   "$WORKSPACE"                 /workspace \
    \
    --dev   /dev \
    --proc  /proc \
    --tmpfs /tmp \
    \
    --setenv HOME         "$HOME" \
    --setenv PATH         "/workspace/.bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
    --setenv CONTACTS_FILE /workspace/contacts.json \
    \
    --chdir /claude_wa \
    \
    -- \
    "$HOME/.local/bin/claude" \
    --print \
    --output-format json \
    "${CLAUDE_ARGS[@]}"
